# Copia este archivo como .env y rellena los valores (no subas .env al repositorio).

# --- Sesión web ---
# WEB_APP_SECRET_KEY=tu-clave-secreta-larga-y-aleatoria
# Solo tu PC (por defecto): WEB_APP_HOST=127.0.0.1
# Misma red Wi‑Fi / túnel ngrok: WEB_APP_HOST=0.0.0.0
# WEB_APP_PORT=5000
# En producción o expuesto: WEB_APP_DEBUG=false
# Activar monitor embebido dentro de web_app.py
# ENABLE_BACKGROUND_MONITOR=false

# --- Correo ---
# NOTIFICACION_EMAILS=correo1@ejemplo.com,correo2@ejemplo.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASSWORD=contraseña_de_aplicacion

# --- Telegram ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_IDS=

# --- Monitor en segundo plano (web_app) ---
# MONITOR_INTERVAL_HOURS=6

# --- Persistencia configurable (útil en hosting) ---
# DB_PATH=monitor_radicados.db
# CARPETA_PDF_PROVIDENCIAS=providencias_pdf
